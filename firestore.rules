rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/data/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /events/{eventId} {
      // Anyone can view events; only the admin can post or remove them
      allow read: if true;
      allow create, update, delete: if request.auth != null &&
        request.auth.token.email == 'fathiyayoosef@gmail.com';
    }

    match /students/{studentId} {
      // Parents may read only records linked to their own email; admin reads all
      allow read: if request.auth != null &&
        (resource.data.parentEmail == request.auth.token.email ||
         request.auth.token.email == 'fathiyayoosef@gmail.com');
      // Only the admin can add or remove students
      allow create, update, delete: if request.auth != null &&
        request.auth.token.email == 'fathiyayoosef@gmail.com';
    }
  }
}
